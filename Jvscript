// O endereço base agora reflete o Blueprint ('/catalog') e a Rota ('/components')
const API_BASE_URL = '/catalog/components';

/**
 * Busca componentes no backend e atualiza a interface. ---------------------QUANDO O USUARIO ACESSA A PAGINA DE BUSCA PELO MENU (SEM FILTRO), PELA PAGINA DE MONTAGEM DE PROJETO (COM O FILTRO DO COMPONENTE) E TODA VEZ QUE O USUARIO CLICA EM PESQUISAR (COM O TEXTO ESCRITO E O FILTRO)
 * @param {string} queryText - O texto digitado pelo usuário (Mapeado para 'q').
 * @param {string} componentType - A categoria filtrada (Mapeado para 'type').
 */
async function searchComponents(queryText = '', componentType = '') {
    try {
        // 1. Montagem dinâmica da URL
        const params = new URLSearchParams();
        
        if (queryText) {
            params.append('q', queryText);
        }
        
        if (componentType) {
            // Atenção aqui: mudamos de 'category' para 'type' para bater com o request.args.get('type')
            params.append('type', componentType); 
        }
        
        const url = `${API_BASE_URL}?${params.toString()}`;
        console.log("Buscando em:", url);

        // 2. Fazendo a requisição GET
        const response = await fetch(url, {
            method: 'GET',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const json = await response.json();
        
        // Se o backend retornar Status 400 (ex: caiu em alguma regra de validação)
        if (!response.ok) {
            throw new Error(json.message || "Erro desconhecido ao buscar peças.");
        }
        
        console.log(json.message); // Ex: "Busca realizada com sucesso!"
        
        // 3. Renderizando os resultados na tela
        renderizarPecas(json.data);

    } catch (erro) {
        console.error("Falha na busca:", erro.message);
        // Exiba o erro na interface (ex: um alert ou uma div vermelha)
        // document.getElementById('mensagem-erro').innerText = erro.message;
    }
}

/**
 * Pega a lista de peças devolvida pelo backend e desenha no HTML ---------------- DESENHA NO FRONTEND
 */
function renderizarPecas(listaPecas) {
    const container = document.getElementById('container-pecas');
    container.innerHTML = ''; // Limpa os resultados anteriores da tela
    
    // Se a busca não retornou nada
    if (listaPecas.length === 0) {
        container.innerHTML = '<p>Nenhuma peça encontrada.</p>';
        return;
    }
    
    // Para cada peça, cria o HTML do card
    listaPecas.forEach(peca => {
        // Usa a imagem Base64 do banco, ou um placeholder se vier vazia
        const imagemSrc = peca.Image ? peca.Image : '/static/img/imagem-indisponivel.jpg';
        
        const cardHTML = `
            <div class="card-peca">
                <img src="${imagemSrc}" alt="${peca.Name}">
                <h4>${peca.Name}</h4>
                <p><strong>Fabricante:</strong> ${peca.Manufacturer}</p>
                <p><strong>Categoria:</strong> ${peca.Categoria}</p>
                
                <button onclick="adicionarAoProjeto(${peca.ID}, '${peca.Categoria}')">Adicionar Peça</button>
            </div>
        `;
        
        container.innerHTML += cardHTML;
    });
}

// ------------------------------------------------------------------------------------------- FORUM ROUTE

// O endereço base agora reflete o Blueprint ('/forum') e a Rota ('/comments')
const FORUM_API_URL = '/forum/comments';

/**
 * Busca os últimos comentários no backend assim que a página é carregada. --- CARREGA OS ULTIMOS 15 COMENTARIOS QUANDO ENTRA NA PAGINA DO FORUM
 */
async function loadComments() {
    try {
        console.log("Buscando comentários em:", FORUM_API_URL);

        // 1. Fazendo a requisição GET (não precisamos de URLSearchParams aqui!)
        const response = await fetch(FORUM_API_URL, {
            method: 'GET',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const json = await response.json();
        
        // Se o backend retornar algum erro de servidor
        if (!response.ok) {
            throw new Error("Erro desconhecido ao carregar o fórum.");
        }
        
        // 2. Renderizando os resultados na tela (passando o array que está em json.data)
        renderizarForum(json.data);

    } catch (erro) {
        console.error("Falha ao carregar comentários:", erro.message);
        // Mostra uma mensagem amigável na tela em caso de falha de conexão
        document.getElementById('forum-container').innerHTML = 
            '<p style="color: red;">Não foi possível carregar os comentários no momento. Tente novamente mais tarde.</p>';
    }
}

/**
 * Pega a lista de comentários devolvida pelo backend e desenha no HTML --- DESENHA NO FRONTEND
 */
function renderizarForum(listaComentarios) {
    const container = document.getElementById('forum-container');
    container.innerHTML = ''; // Limpa o "Carregando..." ou resultados anteriores
    
    // Se a busca não retornou nada (banco de dados vazio)
    if (listaComentarios.length === 0) {
        container.innerHTML = '<p>O fórum está vazio. Seja o primeiro a comentar!</p>';
        return;
    }
    
    // Para cada comentário, cria o HTML do balão
    listaComentarios.forEach(comentario => {
        const cardHTML = `
            <div class="comentario-balao" style="border: 1px solid #ddd; padding: 15px; margin-bottom: 15px; border-radius: 8px;">
                <p style="margin: 0 0 10px 0;">
                    <strong style="color: #0056b3;">${comentario.AuthorName}</strong> 
                    <span style="color: #888; font-size: 0.85em; margin-left: 10px;">(Comentário #${comentario.ID})</span>
                </p>
                <p style="margin: 0; line-height: 1.5;">${comentario.Content}</p>
            </div>
        `;
        
        container.innerHTML += cardHTML;
    });
}

// 3. Gatilho Automático: Chama a função loadComments assim que o HTML da página terminar de carregar
document.addEventListener('DOMContentLoaded', loadComments);

// Usamos a mesma URL base da rota de listagem (GET), mas agora faremos um POST
const FORUM_API_URL = '/forum/comments';

/**
 * Envia um novo comentário para o backend. ------------------------------------ POSTA COMENTARIO (PASSA COMENTARIO, TIPO E ID DO COMPONENTE)
 * @param {string} textoComentario - O texto digitado pelo usuário.
 * @param {number|null} compId - ID do componente (se estiver na página de uma peça).
 * @param {string|null} compType - Tipo do componente (ex: 'GPU', 'CPU').
 */
async function enviarComentario(textoComentario, compId = null, compType = null) {
    // 1. Monta o pacote de dados exatamente como a Rota Flask espera receber
    const dadosRequisicao = {
        content: textoComentario,
        componentId: compId,
        componentType: compType
    };

    try {
        console.log("Enviando comentário...");

        // 2. Faz a requisição POST
        const response = await fetch(FORUM_API_URL, {
            method: 'POST',
            headers: {
                // Essencial: avisa a rota que estamos enviando um JSON
                'Content-Type': 'application/json' 
            },
            // Transforma o objeto JavaScript em uma string JSON para viajar pela rede
            body: JSON.stringify(dadosRequisicao) 
        });

        // 3. Lê a resposta (seja sucesso ou erro, a sua rota sempre devolve um JSON)
        const json = await response.json();

        // Se o status HTTP não for OK (ex: Status 400 por texto vazio ou usuário deslogado)
        if (!response.ok) {
            // Lança o erro com a mensagem exata que o Service Python criou!
            throw new Error(json.message || "Erro desconhecido ao tentar comentar.");
        }

        // 4. Sucesso! (Status 201)
        alert(json.message); // Ex: "Comentário publicado com sucesso!"
        
        // Limpa a caixa de texto para o usuário não enviar duplicado sem querer
        const caixaTexto = document.getElementById('input-comentario');
        if (caixaTexto) {
            caixaTexto.value = '';
        }

        // Chama a função que busca os comentários (do nosso exemplo anterior) 
        // para a tela atualizar na hora e o usuário ver o que acabou de postar!
        if (typeof loadComments === 'function') {
            loadComments();
        }

    } catch (erro) {
        console.error("Falha ao postar:", erro.message);
        // Mostra o erro para o usuário (ex: "Você precisa estar logado para comentar.")
        alert(erro.message); 
    }
}