// Base URL configurada no prefixo do Blueprint de autenticação
const AUTH_BASE_URL = '/auth';

/**
 * 1. Fazer Login
 * Envia as credenciais do usuário e, se der certo, a sessão guardará o user_id.
 * * @param {string} email - E-mail digitado pelo usuário
 * @param {string} password - Senha digitada pelo usuário
 */
async function loginUser(email, password) {
    try {
        const response = await fetch(`${AUTH_BASE_URL}/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, password: password })
        });
        
        const dados = await response.json();
        
        // Se o status HTTP não for 200/2xx, lança o erro para o catch
        if (!response.ok) {
            throw new Error(dados.message); 
        }
        
        console.log("Sucesso:", dados.message);
        
        // Exemplo: Redireciona o usuário para a página de montagem após logar
        // window.location.href = '/builder.html'; 
        
        return dados;
    } catch (erro) {
        console.error("Falha no login:", erro.message);
        // Exiba o erro na interface do usuário (ex: span de erro no formulário)
        // alert("Erro: " + erro.message);
    }
}

/**
 * 2. Criar Conta (Registro)
 * Cadastra o usuário no banco e já efetua o login automaticamente.
 * * @param {string} name - Nome digitado no formulário
 * @param {string} email - E-mail digitado no formulário
 * @param {string} password - Senha digitada no formulário
 */
async function registerUser(name, email, password) {
    try {
        const response = await fetch(`${AUTH_BASE_URL}/register`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name: name, email: email, password: password })
        });
        
        const dados = await response.json();
        
        if (!response.ok) {
            throw new Error(dados.message);
        }
        
        console.log("Conta criada com sucesso:", dados.message);
        
        // Exemplo: Redireciona o usuário para a aplicação já logado
        // window.location.href = '/builder.html';
        
        return dados;
    } catch (erro) {
        console.error("Falha no cadastro:", erro.message);
    }
}

/**
 * 3. Fazer Logout (Sair)
 * Esvazia a sessão no backend, deslogando o usuário por completo.
 */
async function logoutUser() {
    try {
        // Logout não precisa de body, apenas chamamos a rota via POST
        const response = await fetch(`${AUTH_BASE_URL}/logout`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        const dados = await response.json();
        
        if (!response.ok) {
            throw new Error(dados.message);
        }
        
        console.log("Logout realizado:", dados.message);
        
        // Exemplo: Redireciona o usuário de volta para a Home ou tela de Login
        // window.location.href = '/login.html';
        
        return dados;
    } catch (erro) {
        console.error("Erro ao sair:", erro.message);
    }
}